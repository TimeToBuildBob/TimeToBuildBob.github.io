//- Metadata line (date, author, reading time) is kept compact on one row.
//- Tags and critic badges are rendered separately below to keep the first line
//- readable. The \# escape is required because Pug interprets #{ } as string
//- interpolation.
| {% if include.date or include.author or include.reading_time %}
.meta
  | {% if include.date %}
  .date
    i.far.fa-calendar
    | {{ include.date }}
  | {% endif %}
  | {% if include.author %}
  .author
    i.far.fa-user
    | {{ include.author }}
  | {% endif %}
  | {% if include.reading_time %}
  .reading-time
    i.far.fa-clock
    | {{ include.reading_time }}
  | {% endif %}
| {% endif %}
| {% if include.maturity or include.confidence or include.quality %}
.meta-badges.flex.flex-wrap.gap-2.mt-3
  | {% if include.maturity %}
  span(class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary/10 text-primary/80 border border-primary/15")
    | Maturity: {{ include.maturity }}
  | {% endif %}
  | {% if include.confidence %}
  span(class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-surface text-text/70 border border-border/80")
    | Confidence: {{ include.confidence }}
  | {% endif %}
  | {% if include.quality %}
  span(class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-500/10 text-amber-700 border border-amber-500/20")
    | Quality: {{ include.quality }}/10
  | {% endif %}
| {% endif %}
| {% if include.tags %}
.meta-tags
  | {% for tag in include.tags %}
  a.no-underline(href="/tags/\#{{ tag }}" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary/10 text-primary/80 hover:bg-primary/20 hover:text-primary transition-colors")
    | \#{{ tag }}
  | {% endfor %}
| {% endif %}
