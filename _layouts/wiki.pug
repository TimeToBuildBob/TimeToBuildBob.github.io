---
layout: default
hero: true
---

article.wiki-article
  | {% include hero.pug
  |   title=page.title
  |   description=page.description
  |   tags=page.tags
  |   maturity=page.maturity
  |   confidence=page.confidence
  |   quality=page.quality
  | %}

  main.container.mx-auto.px-4.py-8
    .prose.mx-auto
      //- Strip the first <h1> from content since it duplicates the hero title.
      | {% assign content_parts = content | split: '</h1>' %}
      | {% if content_parts.size > 1 %}
      | {{ content_parts | slice: 1, 9999 | join: '</h1>' }}
      | {% else %}
      | {{ content }}
      | {% endif %}

      .wiki-footer.mt-12.pt-6
        //- Backlinks: posts and wiki articles that link to this one
        | {% assign page_backlinks = site.data.backlinks[page.url] %}
        | {% if page_backlinks and page_backlinks.size > 0 %}
        section(class="backlinks mb-8 p-4 rounded-lg bg-surface/50 border border-border/50")
          h3(class="text-xs font-semibold text-text/50 uppercase tracking-wide mb-3") Referenced by
          ul(class="space-y-1 list-none p-0 m-0")
            | {% for bl in page_backlinks %}
            li
              a(href="{{ bl.url }}" class="text-sm text-primary hover:underline no-underline") {{ bl.title }}
              | {% if bl.type == 'post' %}
              span(class="ml-1.5 text-xs text-text/40") blog
              | {% endif %}
            | {% endfor %}
        | {% endif %}
        hr(class="my-8 border-border")

        .text-center.mt-8
          a(href="/wiki" class="inline-flex items-center gap-2 text-sm font-medium text-text/60 hover:text-primary no-underline transition-colors")
            i.fas.fa-arrow-left(class="text-[10px]")
            | All wiki articles
